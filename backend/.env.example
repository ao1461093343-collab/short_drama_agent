# Short Drama Agent backend environment
# Copy this file to .env before running the backend:
#   copy .env.example .env

# App
APP_NAME=Short Drama Agent
USE_MOCK_LLM=true
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Alibaba Bailian / DashScope OpenAI-compatible chat API
# Keep USE_MOCK_LLM=true if you only want to run the demo flow without model quota.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-flash
BAILIAN_TIMEOUT_SECONDS=120
BAILIAN_MAX_TOKENS=2400

# Storage
# auto: use PostgreSQL when available, otherwise fall back to local JSON
# postgres: require PostgreSQL
# json: force local JSON fallback
DATABASE_URL=postgresql+psycopg://drama:drama@localhost:5432/short_drama_agent
DATABASE_CONNECT_TIMEOUT_SECONDS=3
STORAGE_BACKEND=auto

# Long-term memory and retrieval
ENABLE_VECTOR_MEMORY=true
VECTOR_MEMORY_TOP_K=6

# Embedding
# local uses BGE-M3 through sentence-transformers and avoids DashScope embedding quota.
# BGE-M3 vectors are 1024-dimensional.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_EMBEDDING_DEVICE=auto
LOCAL_EMBEDDING_CACHE_DIR=
EMBEDDING_DIMENSION=1024

# Optional DashScope embedding fallback. Use only when EMBEDDING_PROVIDER=dashscope.
BAILIAN_EMBEDDING_MODEL=text-embedding-v4
